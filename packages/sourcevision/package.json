{
  "name": "@n-dx/sourcevision",
  "version": "0.2.1",
  "license": "Elastic-2.0",
  "description": "Codebase analysis tool with structured, git-friendly output",
  "repository": {
    "type": "git",
    "url": "https://github.com/en-dash-consulting/n-dx.git",
    "directory": "packages/sourcevision"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "sourcevision": "./dist/cli/index.js",
    "sv": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run tests/unit tests/integration",
    "test:e2e": "vitest run tests/e2e --no-file-parallelism",
    "test:watch": "vitest",
    "validate": "tsc --noEmit && pnpm run test",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@n-dx/llm-client": "workspace:*",
    "ora": "^8.0.1",
    "pdfkit": "^0.17.2",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/pdfkit": "^0.17.4",
    "vitest": "^4.0.18"
  }
}
