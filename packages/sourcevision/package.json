{
  "name": "sourcevision",
  "version": "0.1.0",
  "license": "Elastic-2.0",
  "description": "Codebase analysis tool with structured, git-friendly output",
  "type": "module",
  "bin": {
    "sourcevision": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsc --noEmit && vitest run",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@n-dx/llm-client": "workspace:*",
    "ora": "^8.0.1",
    "pdfkit": "^0.17.2",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/pdfkit": "^0.17.4",
    "vitest": "^4.0.18"
  }
}
