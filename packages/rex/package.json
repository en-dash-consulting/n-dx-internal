{
  "name": "@n-dx/rex",
  "version": "0.4.0",
  "publishConfig": {
    "access": "public"
  },
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/en-dash-consulting/n-dx.git",
    "directory": "packages/rex"
  },
  "type": "module",
  "bin": {
    "rex": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsc --noEmit && vitest run",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@n-dx/llm-client": "workspace:*",
    "ora": "^8.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.0"
  }
}
