{
  "name": "@n-dx/web",
  "version": "0.4.1",
  "license": "Elastic-2.0",
  "description": "n-dx web dashboard — serves sourcevision, rex, and hench data",
  "repository": {
    "type": "git",
    "url": "https://github.com/en-dash-consulting/n-dx.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "n-dx-web": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "build.js"
  ],
  "scripts": {
    "build": "tsc && node build.js",
    "build:viewer": "node build.js --viewer-only",
    "build:landing": "node build.js --landing-only",
    "dev": "node dev.js",
    "dev:viewer": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node ../../scripts/run-vitest-bind-aware.mjs web",
    "test:watch": "vitest",
    "validate": "tsc --noEmit && vitest run",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@n-dx/llm-client": "workspace:*",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "preact": "^10.19.0",
    "@n-dx/rex": "workspace:*",
    "@n-dx/sourcevision": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.0",
    "@types/d3-selection": "^3.0.0",
    "@types/node": "^25.1.0",
    "esbuild": "^0.27.0",
    "jsdom": "^27.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
